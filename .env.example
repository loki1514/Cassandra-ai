# ============================================
# Cassandra AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# ============================================

# ============================================
# Application Settings
# ============================================
APP_NAME=Cassandra AI
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# ============================================
# Database Settings (PostgreSQL/Supabase)
# ============================================
# NOTE: All DB operations go through Supabase REST API.
# Direct Postgres connection is for optional tooling only.
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_SSL_MODE=require
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# Supabase Settings
# ============================================
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================
# Auth — Cassandra Session Tokens
# ============================================
# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
CASSANDRA_TOKEN_SECRET=generate-your-64-byte-hex-secret-here
# Session token lifetime in seconds (21600 = 6 hours)
CASSANDRA_TOKEN_EXPIRE_SECONDS=21600
# FMS Supabase URL — the Supabase that authenticates the React console admin.
# NOT the same as the Cassandra database Supabase above.
FMS_SUPABASE_URL=https://your-fms-project.supabase.co

# ============================================
# ElevenLabs TTS (REQUIRED for orb to talk)
# ============================================
# Get from: https://elevenlabs.io/api
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_DEFAULT_VOICE=alloy
ELEVENLABS_MODEL=eleven_multilingual_v2

# ============================================
# AssemblyAI Settings (Transcription + Diarization)
# ============================================
# Get from: https://www.assemblyai.com
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
ASSEMBLYAI_WEBHOOK_SECRET=your-webhook-secret
ASSEMBLYAI_DEFAULT_LANGUAGE=en
ASSEMBLYAI_ENABLE_SPEAKER_DIARIZATION=true

# ============================================
# Anthropic (Claude — some LLM operations)
# ============================================
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================
# OpenAI Settings (LLM, Embeddings)
# ============================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORGANIZATION=your-org-id
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# ============================================
# Provider Selection
# ============================================
# VAD: silero (free CPU) or deepgram (paid)
VAD_PROVIDER=silero
# STT: openai (whisper), assemblyai, or deepgram
STT_PROVIDER=openai
# TTS: elevenlabs or openai
TTS_PROVIDER=elevenlabs

# ============================================
# Audio Config
# ============================================
AUDIO_SAMPLE_RATE=24000
AUDIO_CHUNK_DURATION_MS=100
VAD_PROBABILITY_THRESHOLD=0.5
VAD_SILENCE_THRESHOLD_MS=750
VAD_PREFIX_PADDING_MS=450

# ============================================
# Session Config
# ============================================
SESSION_IDLE_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_SESSIONS=100

# ============================================
# Vector Store Settings (Pinecone/Weaviate)
# ============================================
# REQUIRED for semantic memory search.
VECTOR_PROVIDER=pinecone
VECTOR_API_KEY=your-vector-api-key
VECTOR_ENVIRONMENT=us-east1-gcp
VECTOR_INDEX_NAME=cassandra-memories
VECTOR_DIMENSION=1536
VECTOR_METRIC=cosine

# ============================================
# Redis Settings (Caching — optional)
# ============================================
# Falls back to in-memory if not configured.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# ============================================
# Security Settings
# ============================================
SECURITY_JWT_ALGORITHM=HS256
SECURITY_JWT_EXPIRATION_HOURS=24
SECURITY_JWT_REFRESH_EXPIRATION_DAYS=7
SECURITY_PASSWORD_MIN_LENGTH=8
SECURITY_ENABLE_CORS=true
# Allow origins for CORS — include Expo localhost and your deployed URLs.
# In development: http://localhost:3000 (web), exp://localhost:8081 (Expo)
# In production: your deployed domain.
SECURITY_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
SECURITY_ENCRYPTION_ENABLED=true

# ============================================
# Logging Settings
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_JSON_FORMAT=false
LOG_FILE_PATH=

# ============================================
# Supermemory Settings (Conversational Memory)
# ============================================
# OPTIONAL — enables dual-read from Supermemory.
# If not configured, falls back to Supabase-only queries.
# Get API key from: https://supermemory.ai
SUPERMEMORY_API_URL=https://api.supermemory.ai
SUPERMEMORY_API_KEY=your-supermemory-api-key
SUPERMEMORY_ORG_ID_HEADER=x-org-id
SUPERMEMORY_SEARCH_ENDPOINT=/search
SUPERMEMORY_TIMEOUT_SECONDS=10

# ============================================
# AWS Settings (KMS, S3 — optional)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_KMS_KEY_ALIAS_PREFIX=alias/cassandra-org
AWS_S3_BUCKET=cassandra-ai-uploads

# ============================================
# Circuit Breaker
# ============================================
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30

# ============================================
# Rate Limits (per org per hour, 0 = unlimited)
# ============================================
LIMIT_TENANT=5400
LIMIT_SUPER_TENANT=5400
LIMIT_ADMIN=5400
LIMIT_ORG_SUPER_ADMIN=0
LIMIT_OWNER=0
LIMIT_MASTER_ADMIN=0

# ============================================
# Tool / External Integrations (optional)
# ============================================
AUTOPILOT_API_BASE_URL=
AUTOPILOT_API_KEY=

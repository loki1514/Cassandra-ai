# ============================================
# Cassandra AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# ============================================

# ============================================
# Application Settings
# ============================================
APP_NAME=Cassandra AI
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# ============================================
# Database Settings (PostgreSQL/Supabase)
# ============================================
DB_HOST=your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_SSL_MODE=require
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# Supabase Settings
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================
# AWS Settings (KMS, S3)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_KMS_KEY_ALIAS_PREFIX=alias/cassandra-org
AWS_S3_BUCKET=cassandra-ai-uploads

# ============================================
# AssemblyAI Settings (Transcription)
# ============================================
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
ASSEMBLYAI_WEBHOOK_SECRET=your-webhook-secret
ASSEMBLYAI_DEFAULT_LANGUAGE=en
ASSEMBLYAI_ENABLE_SPEAKER_DIARIZATION=true

# ============================================
# OpenAI Settings (LLM, Embeddings)
# ============================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORGANIZATION=your-org-id
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# ============================================
# Vector Store Settings (Pinecone/Weaviate)
# ============================================
VECTOR_PROVIDER=pinecone
VECTOR_API_KEY=your-vector-api-key
VECTOR_ENVIRONMENT=us-east1-gcp
VECTOR_INDEX_NAME=cassandra-memories
VECTOR_DIMENSION=1536
VECTOR_METRIC=cosine

# ============================================
# Redis Settings (Caching)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# ============================================
# Security Settings
# ============================================
SECURITY_JWT_ALGORITHM=HS256
SECURITY_JWT_EXPIRATION_HOURS=24
SECURITY_JWT_REFRESH_EXPIRATION_DAYS=7
SECURITY_PASSWORD_MIN_LENGTH=8
SECURITY_ENABLE_CORS=true
SECURITY_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
SECURITY_ENCRYPTION_ENABLED=true

# ============================================
# Logging Settings
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_JSON_FORMAT=false
LOG_FILE_PATH=

# ═══════════════════════════════════════════════════════════════
# Cassandra Voice Server — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-2024-08-06
OPENAI_WHISPER_MODEL=whisper-1

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ── ElevenLabs TTS ─────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_DEFAULT_VOICE=alloy
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Provider Selection ──────────────────────────────────────
# Options: silero, deepgram, livekit
VAD_PROVIDER=silero

# Options: openai, deepgram
STT_PROVIDER=openai

# Options: elevenlabs, openai
TTS_PROVIDER=elevenlabs

# ── Rate Limits (seconds/month per role) ────────────────────
LIMIT_TENANT=5400
LIMIT_SUPER_TENANT=5400
LIMIT_ADMIN=5400
LIMIT_ORG_SUPER_ADMIN=0
LIMIT_OWNER=0
LIMIT_MASTER_ADMIN=0

# ── Audio Config ────────────────────────────────────────────
AUDIO_SAMPLE_RATE=24000
AUDIO_CHUNK_DURATION_MS=100
VAD_PROBABILITY_THRESHOLD=0.5
VAD_SILENCE_THRESHOLD_MS=750
VAD_PREFIX_PADDING_MS=450

# ── Session Config ──────────────────────────────────────────
SESSION_IDLE_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_SESSIONS=100

# ── Circuit Breaker ─────────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30

# ── Autopilot Webhook ────────────────────────────────────────
AUTOPILOT_API_BASE_URL=https://api.autopilot.example.com
AUTOPILOT_API_KEY=...

# ── Console Page (Frontend) ─────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
